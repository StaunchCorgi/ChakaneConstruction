<section id="contact" class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Contact Us</h2>
            <p class="text-muted">Have a project in mind? Get in touch with us for reliable maintenance and construction services.</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="p-4 shadow-sm rounded bg-light h-100">
                    <h4 class="fw-bold mb-4">Get In Touch</h4>

                    <div class="mb-3">
                        <h6 class="fw-bold mb-1"><i class="bi bi-telephone-fill text-primary me-2"></i>Phone</h6>
                        <p class="text-muted mb-0">+27 79 268 0842</p>
                    </div>

                    <div class="mb-3">
                        <h6 class="fw-bold mb-1"><i class="bi bi-envelope-fill text-primary me-2"></i>Email</h6>
                        <p class="text-muted mb-0">a.chakane@kcmcons.co.za</p>
                    </div>

                    <div class="mb-3">
                        <h6 class="fw-bold mb-1"><i class="bi bi-geo-alt-fill text-primary me-2"></i>Location</h6>
                        <p class="text-muted mb-0">Krugersdorp, South Africa</p>
                    </div>

                    <div>
                        <h6 class="fw-bold mb-1"><i class="bi bi-clock-fill text-primary me-2"></i>Working Hours</h6>
                        <p class="text-muted mb-0">Mon - Fri: 08:00 - 17:00</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="p-4 shadow-sm rounded bg-white">
                    <form asp-controller="Home" asp-action="GetQuote" method="post">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Full Name</label>
                                <input type="text" class="form-control" name="FullName" placeholder="Your full name" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Phone Number</label>
                                <input type="text" class="form-control" name="ContactNumber" placeholder="+27 ..." />
                            </div>

                            <div class="col-12">
                                <label class="form-label">Email Address</label>
                                <input type="email" class="form-control" name="Email" placeholder="you@example.com" />
                            </div>

                            <div class="col-12">
                                <label class="form-label">Service Needed</label>
                                <select class="form-select" name="Service">
                                    <option value="" selected disabled>Select a service</option>
                                    <option>Painting</option>
                                    <option>Paving</option>
                                    <option>Tiling</option>
                                    <option>Carpentry</option>
                                    <option>Glazing</option>
                                    <option>Waterproofing</option>
                                    <option>Bricklaying</option>
                                    <option>General Maintenance</option>
                                    <option>Road Maintenance</option>
                                    <option>Other</option>
                                </select>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Message</label>
                                <textarea class="form-control" name="Message" rows="5" placeholder="Tell us about your project"></textarea>
                            </div>

                            <div class="col-12">
                                <button type="submit" class="btn btn-danger btn-lg">Send Request</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
